# ----- App -----
NODE_ENV=development
PORT=3100
APP_URL=http://localhost:3100
SESSION_SECRET=replace-with-long-random-string
JWT_SECRET=replace-with-long-random-string

# ----- Database (Prisma) -----
# Dev defaults to SQLite for zero-setup. For production use PostgreSQL:
#   DATABASE_URL="postgresql://user:pass@host:5432/medsupply"
DATABASE_URL="file:./dev.db"

# ----- ECPay 綠界金流 (Sandbox defaults) -----
